# Sentinela RJ — variáveis de ambiente
# Copie este arquivo para .env e ajuste os valores:
#   cp .env.example .env
#
# Todas as variáveis são opcionais: o sistema funciona com os padrões abaixo.
# Variáveis sem valor padrão precisam ser definidas para ativar a funcionalidade.


# ── Banco de dados ────────────────────────────────────────────────────────────

# Caminho absoluto para o arquivo SQLite.
# Padrão: <raiz_do_projeto>/data/sentinela_rj.db
# DB_PATH=/caminho/customizado/sentinela_rj.db


# ── API do PNCP ───────────────────────────────────────────────────────────────

# URL base da API pública do PNCP (não requer autenticação).
# Padrão: https://pncp.gov.br/api/consulta/v1
# PNCP_BASE_URL=https://pncp.gov.br/api/consulta/v1

# Timeout em segundos por requisição HTTP.
# Padrão: 60
# PNCP_TIMEOUT=60

# Número máximo de registros por página (limite da API: 500).
# Padrão: 500
# PNCP_TAM_PAGINA=500


# ── Filtro geográfico ─────────────────────────────────────────────────────────

# Código IBGE do município monitorado.
# Padrão: 3304557 (Rio de Janeiro)
# MUNICIPIO_IBGE=3304557

# Esfera de governo: M=Municipal, E=Estadual, F=Federal.
# Padrão: M
# MUNICIPIO_ESFERA=M

# Nome legível do município (logs e relatórios).
# MUNICIPIO_NOME=Rio de Janeiro


# ── Backfill histórico PNCP ───────────────────────────────────────────────────

# Data inicial padrão para `python __main__.py backfill` (AAAAMMDD).
# BACKFILL_DATA_INICIO=20220101


# ── Sanções CEIS/CNEP (CSV Portal da Transparência) ───────────────────────────

# URLs dos CSV/ZIP ou arquivos locais em data/raw/sancoes/
# SANCOES_CEIS_URL=
# SANCOES_CNEP_URL=
# SANCOES_DIR=data/raw/sancoes


# ── Transparência RJ (cross-reference empenhos) ───────────────────────────────

# CSV de empenhos/despesas (dados abertos PMRJ).
# TRANSPARENCIA_RJ_EMPENHOS_URL=
# TRANSPARENCIA_RJ_EMPENHOS_PATH=data/raw/transparencia_rj/empenhos.csv


# ── Análise de anomalias ──────────────────────────────────────────────────────

# Janela em dias para o detector de concentração de fornecedor.
# Padrão: 90
# CONCENTRACAO_JANELA_DIAS=90

# Valor mínimo (R$) para acionar o detector de concentração.
# Evita falsos positivos em compras rotineiras de baixo valor (ex: medicamentos).
# Padrão: 1000000
# CONCENTRACAO_MIN_VALOR=1000000

# Score mínimo para incluir anomalia na seção de detalhamento do relatório.
# Padrão: 0.70
# RELATORIO_SCORE_MINIMO=0.70


# ── Narrativa investigativa (IA) ──────────────────────────────────────────────

# Provedor padrão: ollama | gemini | groq
# SENTINELA_IA_PROVIDER=ollama

# Ollama local (padrão) — requer: ollama pull llama3.1
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1
# OLLAMA_TIMEOUT=120

# Fallback opcional se Ollama indisponível (ou SENTINELA_IA_PROVIDER=gemini)
# GEMINI_API_KEY=

# Revisão por IA superior: rascunho Ollama → auditoria Gemini (padrão: true se chave existir)
# SENTINELA_IA_REVISAO_GEMINI=true

# Fallback opcional (ou SENTINELA_IA_PROVIDER=groq)
# GROQ_API_KEY=


# ── Dashboard Flask (UI canônica) ─────────────────────────────────────────────

# Porta do servidor web (web_app.py).
# Padrão: 5055
# SENTINELA_WEB_PORT=5055


# ── Pipeline agendado (automacoes/pipeline.py) ────────────────────────────────

# Janela retroativa de coleta PNCP (dias).
# PIPELINE_JANELA_DIAS=90

# Limites por execucao (0 = sem limite em enriquecer).
# PIPELINE_ENRIQUECER_LIMITE=0
# PIPELINE_INVESTIGAR_LIMITE=10
# PIPELINE_IA_INTERVALO_S=13

# Discord — novos alertas de alta severidade.
# DISCORD_WEBHOOK_URL=
# PIPELINE_DISCORD_MAX=5
# PIPELINE_DISCORD_RESUMO=true
# PIPELINE_DISCORD_INTERVALO_S=1

# Etapas opcionais.
# PIPELINE_SKIP_ENRIQUECER=false
# PIPELINE_SKIP_INVESTIGAR=false
# PIPELINE_SKIP_NOTIFICAR=false
# PIPELINE_ABORT_ON_ERROR=false

# Scheduler (--daemon): cron padrao segunda 08:00.
# PIPELINE_CRON=0 8 * * 1
# PIPELINE_TIMEZONE=America/Sao_Paulo
# PIPELINE_RUN_ON_START=false
